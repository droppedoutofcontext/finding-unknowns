+ALTER TABLE orders RENAME COLUMN status TO state;
+ALTER INDEX idx_orders_status RENAME TO idx_orders_state;
+-- introduce intermediate 'charging' state used for idempotency claims
+UPDATE orders SET state = 'pending' WHERE state IS NULL;
